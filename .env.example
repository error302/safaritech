# Database - Prisma Accelerate Connection String
# DATABASE_URL is used by Prisma CLI (generate, migrate, etc.)
# DATABASE_URL_ACCELERATE is used by the runtime PrismaClient to ensure
# the Accelerate URL is used even if another DATABASE_URL is in the system env.
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"
DATABASE_URL_ACCELERATE="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# NextAuth Configuration
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://yourdomain.com"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# M-Pesa
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
MPESA_ENV="sandbox"

# Email
RESEND_API_KEY=""

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="safaritech"

# PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_API_URL="https://api-m.sandbox.paypal.com"
PAYPAL_USD_TO_KES_RATE="130.0"
