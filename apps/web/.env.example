# ──────────────────────────────────────────────────────────────────────────────
# Safaritech E-Commerce — Environment Variables
# Copy this file to .env.local and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# Database - Prisma Accelerate Connection String
# Get your Accelerate URL from https://console.prisma.io
# DATABASE_URL is used by Prisma CLI (generate, migrate, etc.)
# DATABASE_URL_ACCELERATE is used by the runtime PrismaClient to ensure
# the Accelerate URL is used even if another DATABASE_URL is in the system env.
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"
DATABASE_URL_ACCELERATE="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"

# NextAuth Configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# For local development:
NEXTAUTH_URL="http://localhost:3000"
# For production (Vercel):
# NEXTAUTH_URL="https://safaritech.vercel.app"

# Stripe (Card Payments)
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# M-Pesa (Safaricom Daraja API)
# Get your credentials from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
MPESA_ENV="sandbox"

# Email (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=""

# Cloudinary (Image Uploads)
# Get your credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="safaritech"

# PayPal
# Get your credentials from https://developer.paypal.com/dashboard
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_API_URL="https://api-m.sandbox.paypal.com"
PAYPAL_USD_TO_KES_RATE="130.0"
